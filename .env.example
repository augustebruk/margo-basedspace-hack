# ---- Server-side (never commit a real key; .env is gitignored) ----
# Your Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the Live model used by the proxy.
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
# Optional: port the WebSocket proxy listens on (keep in sync with VITE_LIVE_WS_URL).
LIVE_WS_PORT=8787

# ---- Frontend (Vite — exposed to the browser) ----
# WebSocket URL the <LiveVoiceAgent/> connects to.
VITE_LIVE_WS_URL=ws://localhost:8787
# Set to "true" to show the Live voice (Gemini) panel in the entry screen.
VITE_ENABLE_LIVE=false
