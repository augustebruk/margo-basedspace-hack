# ElevenLabs Speech-to-Text (Scribe v2 Realtime)
#
# Server-side ONLY. The Vite token middleware (vite-plugins/scribeToken.ts)
# reads this to mint short-lived single-use tokens for the browser. Do NOT add a
# VITE_ prefix — that would inline the secret into the client bundle.
#
# Get a key at https://elevenlabs.io/app/settings/api-keys
# Copy this file to `.env` and fill in your key.
ELEVENLABS_API_KEY=

# Anthropic Claude — generates the reflection (summary / patterns / next steps)
# from the journal transcript. Server-side ONLY (the /api/reflection proxy in
# vite-plugins/reflection.ts reads it); no VITE_ prefix. If unset, the app falls
# back to a built-in mock reflection so the flow still works for demos.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
