# ElevenLabs Speech-to-Text (Scribe v2 Realtime)
#
# Server-side ONLY. The Vite token middleware (vite-plugins/scribeToken.ts)
# reads this to mint short-lived single-use tokens for the browser. Do NOT add a
# VITE_ prefix — that would inline the secret into the client bundle.
#
# Get a key at https://elevenlabs.io/app/settings/api-keys
# Copy this file to `.env` and fill in your key.
ELEVENLABS_API_KEY=

# ElevenLabs Text-to-Speech (Margo's voice during onboarding)
#
# Server-side ONLY. The /api/tts proxy (vite-plugins/tts.ts) reads ELEVENLABS_API_KEY
# above and streams synthesized audio back to the browser, so the key is never
# exposed to the client. ELEVENLABS_VOICE_ID is optional — set it to choose a
# specific voice; if unset, a warm default voice is used. If TTS fails, the
# onboarding flow degrades gracefully (text still advances, just without audio).
# Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=

# Anthropic Claude — generates the reflection (summary / patterns / next steps)
# from the journal transcript. Server-side ONLY (the /api/reflection proxy in
# vite-plugins/reflection.ts reads it); no VITE_ prefix. If unset, the app falls
# back to a built-in mock reflection so the flow still works for demos.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Skip the first-run onboarding flow (the "Your First Mirror Moment" voice
# intro). Set to 1 to go straight to the journaling app. Client-side flag, so
# it MUST keep the VITE_ prefix to be readable in the browser bundle. Leave
# unset (or any value other than 1) to show onboarding for new users.
VITE_SKIP_ONBOARDING=

# Override name — when set, always used as the person's name, taking precedence
# over any name captured during onboarding (handy for prod demos). Client-side
# flag, so it MUST keep the VITE_ prefix. Leave unset to use the captured name.
VITE_OVERRIDE_NAME=

# Stripe
STRIPE_SK=
STRIPE_PK=