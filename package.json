    "preview": "vite preview",
    "start": "node server.js"
  },
  "dependencies": {
    "@elevenlabs/client": "^1.9.0",
    "motion": "^12.40.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
